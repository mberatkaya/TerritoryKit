{
  "name": "territory-kit",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript-first geospatial territory engine for hierarchical polygon datasets.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "bench": "turbo run bench",
    "benchmark:compare": "node scripts/benchmark-compare.mjs",
    "benchmark:fixture": "node scripts/benchmark-fixture.mjs",
    "benchmark:run": "node scripts/benchmark-run.mjs",
    "bench:memory": "pnpm build && node --expose-gc scripts/measure-core-memory.mjs",
    "build": "turbo run build",
    "bundle:size": "node scripts/check-bundle-size.mjs",
    "clean": "turbo run clean && rimraf node_modules",
    "changeset": "changeset",
    "country:smoke": "node scripts/country-smoke.mjs",
    "coverage": "vitest run --coverage",
    "docs:build": "pnpm --filter @territory-kit/docs build",
    "docs:dev": "pnpm --filter @territory-kit/docs dev",
    "docs:links": "node scripts/check-doc-links.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "geometry:validate:fixtures": "pnpm --filter @territory-kit/dataset exec vitest run test/geometry-quality.test.ts --passWithNoTests && pnpm --filter @territory-kit/cli exec vitest run test/cli.test.ts --passWithNoTests",
    "lint": "turbo run lint",
    "package:boundaries": "node scripts/check-package-boundaries.mjs",
    "package:dry-run": "node scripts/package-dry-run.mjs",
    "prepublishOnly": "node -e \"throw new Error('Root workspace must not be published. Publish packages from packages/* only.')\"",
    "query-render:smoke": "node scripts/query-render-compatibility-smoke.mjs",
    "registry:generate": "node scripts/generate-dataset-registry.mjs",
    "release": "pnpm build && node scripts/publish-packages.mjs",
    "release:check": "node scripts/release-check.mjs",
    "registry:smoke": "node scripts/registry-install-smoke.mjs",
    "test": "turbo run test",
    "test:visual:maplibre": "pnpm --filter @territory-kit/example-web-maplibre test:visual",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm package:boundaries && pnpm typecheck && pnpm test && pnpm build && pnpm bundle:size",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.0.1",
    "tinybench": "^6.0.2",
    "tsdown": "^0.22.7",
    "turbo": "^2.10.4",
    "typedoc": "^0.28.20",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10"
  }
}
