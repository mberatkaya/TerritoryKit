{
  "name": "@territory-kit/nestjs",
  "version": "1.0.0",
  "description": "NestJS integration boundary for TerritoryKit and PostGIS-backed repositories.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "@nestjs/common": ">=11",
    "@nestjs/swagger": ">=11",
    "rxjs": ">=7"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist coverage .turbo",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --no-error-on-unmatched-pattern",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@territory-kit/core": "workspace:*",
    "@territory-kit/dataset": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@territory-kit/shared-testkit": "workspace:*",
    "rxjs": "^7.8.2"
  }
}
