{
  "name": "@territory-kit/generators",
  "version": "0.6.0-alpha.0",
  "description": "Generator and deterministic dataset utility helpers for TerritoryKit.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist coverage .turbo",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --no-error-on-unmatched-pattern",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@territory-kit/core": "workspace:*",
    "@territory-kit/dataset": "workspace:*"
  },
  "devDependencies": {
    "@territory-kit/shared-testkit": "workspace:*"
  }
}
