{
  "name": "@territory-kit/core",
  "version": "1.1.0",
  "description": "Core TerritoryKit zone engine, hierarchy, adjacency, and spatial queries.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/mberatkaya/TerritoryKit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mberatkaya/TerritoryKit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mberatkaya/TerritoryKit/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/*.cjs",
    "dist/*.d.cts",
    "dist/*.d.mts",
    "dist/*.mjs",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./legacy-registry": {
      "types": "./dist/legacy-registry.d.mts",
      "import": "./dist/legacy-registry.mjs",
      "require": "./dist/legacy-registry.cjs"
    }
  },
  "scripts": {
    "bench": "vitest bench --run",
    "build": "tsdown",
    "clean": "rimraf dist coverage .turbo",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --no-error-on-unmatched-pattern",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@territory-kit/dataset": "workspace:*",
    "@territory-kit/registry": "workspace:*",
    "flatbush": "^4.6.2"
  },
  "devDependencies": {
    "@territory-kit/shared-testkit": "workspace:*"
  }
}
